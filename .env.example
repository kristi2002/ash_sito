# ============================================================
#  Configurazione email — A.S.H. Finiture Contract
#
#  Copia questo file in .env solo per lo sviluppo locale.
#  In produzione (Coolify) imposta queste variabili in
#  Application -> Environment Variables.
# ============================================================

# ---- Mittente --------------------------------------------------
# IMPORTANTE: con Gmail e Outlook l'indirizzo mittente DEVE essere
# la stessa casella con cui fai il login SMTP (MAIL_SMTP_USER),
# altrimenti l'invio viene rifiutato o finisce in spam.
MAIL_FROM_EMAIL=ashfiniturecontract@outlook.it
MAIL_FROM_NAME="A.S.H. Finiture Contract"

# ---- Server SMTP -----------------------------------------------
MAIL_SMTP_HOST=smtp.office365.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=ashfiniturecontract@outlook.it
MAIL_SMTP_PASSWORD=
# Cifratura: tls (STARTTLS, porta 587) | ssl (SMTPS, porta 465) | none
MAIL_SMTP_SECURE=tls

# ---- Diagnostica -----------------------------------------------
# MAIL_DEBUG=1 scrive il dialogo SMTP completo nel log errori PHP
# (utile se le mail non partono; togli o metti 0 in produzione).
# MAIL_DEBUG=1

# MAIL_SMTP_ALLOW_INSECURE=1 disattiva la verifica del certificato
# TLS. Solo come ultima spiaggia con host "artigianali"; MAI con
# Gmail/Outlook.
# MAIL_SMTP_ALLOW_INSECURE=1

# ================================================================
#  RICETTE PER I PROVIDER PIÙ COMUNI
# ================================================================
#
# --- Outlook / Hotmail personale (outlook.it, outlook.com) ------
#   MAIL_SMTP_HOST=smtp-mail.outlook.com   (ok anche smtp.office365.com)
#   MAIL_SMTP_PORT=587
#   MAIL_SMTP_SECURE=tls
#   MAIL_SMTP_USER=tuacasella@outlook.it
#   MAIL_SMTP_PASSWORD=<password per le app>
#   Microsoft ha disattivato l'accesso con la password normale:
#   1) attiva la verifica in due passaggi su account.microsoft.com/security
#   2) crea una "Password per le app" e usala come MAIL_SMTP_PASSWORD
#
# --- Microsoft 365 aziendale ------------------------------------
#   MAIL_SMTP_HOST=smtp.office365.com
#   MAIL_SMTP_PORT=587
#   MAIL_SMTP_SECURE=tls
#   Nel Microsoft 365 Admin Center abilita per la casella:
#   Utenti attivi -> [casella] -> Posta -> "SMTP autenticato".
#
# --- Gmail / Google Workspace -----------------------------------
#   MAIL_SMTP_HOST=smtp.gmail.com
#   MAIL_SMTP_PORT=587
#   MAIL_SMTP_SECURE=tls
#   MAIL_SMTP_USER=tuacasella@gmail.com
#   MAIL_SMTP_PASSWORD=<password per le app>
#   La password normale NON funziona:
#   1) attiva la verifica in due passaggi su myaccount.google.com/security
#   2) crea una password su myaccount.google.com/apppasswords
#      (16 lettere, inseriscila senza spazi)
#
# --- Aruba ------------------------------------------------------
#   MAIL_SMTP_HOST=smtps.aruba.it
#   MAIL_SMTP_PORT=465
#   MAIL_SMTP_SECURE=ssl
#   MAIL_SMTP_USER=casella@tuodominio.it   (indirizzo completo)
#
# --- Register.it ------------------------------------------------
#   MAIL_SMTP_HOST=authsmtp.register.it
#   MAIL_SMTP_PORT=587
#   MAIL_SMTP_SECURE=tls
#
# Nota deliverability: per non finire in spam su Gmail/Outlook,
# invia sempre dalla casella reale del dominio/provider che usi per
# l'autenticazione (SPF/DKIM del provider coprono l'invio). Il
# modulo del sito mette l'email del cliente in Reply-To, quindi
# "Rispondi" scrive direttamente al cliente.
